# ─────────────────────────────────────────
# CONFIGURACIÓN DEL BOT
# Copia este archivo como .env y rellena los valores
# NUNCA subas el archivo .env a GitHub
# ─────────────────────────────────────────

# Token de tu bot (Portal de Desarrolladores de Discord)
DISCORD_TOKEN=TU_TOKEN_AQUI

# ID de tu aplicación (Portal de Desarrolladores)
CLIENT_ID=TU_CLIENT_ID_AQUI

# ID de tu servidor de pruebas (para registrar comandos rápido durante desarrollo)
GUILD_ID=TU_GUILD_ID_AQUI

# Prefijo para comandos de texto (legacy, además de slash commands)
PREFIX=!

# ─────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────
DB_PATH=./data/database.sqlite

# ─────────────────────────────────────────
# PREMIUM (si usas Stripe)
# ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_AQUI
STRIPE_WEBHOOK_SECRET=whsec_AQUI

# ─────────────────────────────────────────
# LINKS DEL BOT (para el comando !donate, etc.)
# ─────────────────────────────────────────
BOT_SUPPORT_SERVER=https://discord.gg/TUSERVIDOR
BOT_INVITE_LINK=https://discord.com/api/oauth2/authorize?client_id=TU_CLIENT_ID&permissions=8&scope=bot%20applications.commands
BOT_WEBSITE=https://tubotmusica.com
BOT_DONATE_LINK=https://ko-fi.com/tubotmusica

# ─────────────────────────────────────────
# ENTORNO
# ─────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
